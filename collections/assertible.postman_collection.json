      "id": "dd342787-1451-4b04-9f54-b87bb17f2ced",
      "name": "Deployments",
      "description": {
        "content": "Notify Assertible of deployments and trigger tests",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "f8dc75fe-17f8-4871-905a-12e903b9d25c",
          "name": "Track a deployment and trigger its tests",
          "request": {
            "name": "Track a deployment and trigger its tests",
            "description": {
              "content": "Notifies Assertible that a deployment has occurred for the\nidentified web service. Triggers any deployment-targeted tests and\nrecords the deployment ref/version for traceability.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "deployments"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{basicAuthUsername}}"
                },
                {
                  "key": "password",
                  "value": "{{basicAuthPassword}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service\": \"<uuid>\",\n  \"version\": \"<string>\",\n  \"environment\": \"production\",\n  \"environmentUrl\": \"<uri>\",\n  \"ref\": \"<string>\",\n  \"url\": \"<uri>\",\n  \"github\": \"<boolean>\",\n  \"repository\": \"<string>\",\n  \"tests\": [\n    \"<uuid>\",\n    \"<uuid>\"\n  ],\n  \"testGroups\": [\n    \"<string>\",\n    \"<string>\"\n  ],\n  \"wait\": \"<boolean>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
